function editUserPin(userId) {
    const newPin = prompt('Masukkan PIN baru (4-6 digit):', state.users[userId].pin);
    if(newPin && newPin.length >= 4 && newPin.length <= 6) {
        state.users[userId].pin = newPin;
        saveData();
        loadAdminData();
        showToast('PIN berhasil diubah!');
    } else if(newPin) {
        showToast('PIN harus 4-6 digit!');
    }
}

function resetAllData() {
    const pass = document.getElementById('resetConfirmPass').value;
    if(pass !== state.users.admin.pin) {
        showToast('Password admin salah!');
