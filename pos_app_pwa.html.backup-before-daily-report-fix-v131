    const id = el.id;
    if(id === 'toggleDark') state.settings.darkMode = el.classList.contains('active');
    if(id === 'toggleSound') state.settings.sound = el.classList.contains('active');
    if(id === 'toggleAutoPrint') state.settings.autoPrint = el.classList.contains('active');
    if(id === 'toggleBluetooth') state.settings.bluetoothPrinter = el.classList.contains('active');
