function updateStats() {
    const today = new Date().toISOString().split('T')[0];
    const thisMonth = today.slice(0, 7);

    const todayTxs = state.transactions.filter(t => t.date.startsWith(today));
    const monthTxs = state.transactions.filter(t => t.date.startsWith(thisMonth));

    document.getElementById('statTodayCount').textContent = todayTxs.length;
    document.getElementById('statTodayRevenue').textContent = 'Rp ' + formatNumber(todayTxs.reduce((s,t) => s + t.total, 0));
    document.getElementById('statMonthCount').textContent = monthTxs.length;
    document.getElementById('statMonthRevenue').textContent = 'Rp ' + formatNumber(monthTxs.reduce((s,t) => s + t.total, 0));
