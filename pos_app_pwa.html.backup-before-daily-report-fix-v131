</div>
</div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
// ==================== DATA ====================
const DEFAULT_MENU = [
    // Coffee
    {id:'c1',name:'Americano',price:8000,category:'coffee',emoji:'☕',badge:'',desc:'Kopi hitam klasik'},
    // Milo Series
    {id:'m1',name:'Milo Malaysia',price:12000,category:'milo',emoji:'🍫',badge:'BEST SELLER',desc:'Milo khas Malaysia'},
    {id:'m2',name:'Coffee Milo',price:12000,category:'milo',emoji:'☕',badge:'BEST SELLER',desc:'Perpaduan kopi & milo'},
    {id:'m3',name:'Milo Butterscotch',price:12000,category:'milo',emoji:'🍫',badge:'BEST SELLER',desc:'Milo rasa butterscotch'},
    {id:'m4',name:'Milo Hazelnut',price:12000,category:'milo',emoji:'🍫',badge:'',desc:'Milo dengan hazelnut'},
    {id:'m5',name:'Milo Caramel',price:12000,category:'milo',emoji:'🍫',badge:'',desc:'Milo rasa caramel'},
    // Matcha Series
    {id:'ma1',name:'Matcha Aren',price:12000,category:'matcha',emoji:'🍵',badge:'BEST SELLER',desc:'Matcha dengan gula aren'},
    {id:'ma2',name:'Matchapresso',price:12000,category:'matcha',emoji:'🍵',badge:'BEST SELLER',desc:'Matcha espresso blend'},
    // Signature Coffee
    {id:'s1',name:'Renjana',price:10000,category:'signature',emoji:'⭐',badge:'BEST SELLER',desc:'Strong coffee gula aren'},
    {id:'s2',name:'Kahwa',price:10000,category:'signature',emoji:'⭐',badge:'',desc:'Black coffee gula aren'},
    {id:'s3',name:'Sakala',price:10000,category:'signature',emoji:'⭐',badge:'',desc:'Soft coffee gula aren'},
    // Premium Coffee
    {id:'p1',name:'Caramel',price:12000,category:'premium',emoji:'💎',badge:'BEST SELLER',desc:'Kopi premium caramel'},
    {id:'p2',name:'Hazelnut',price:12000,category:'premium',emoji:'💎',badge:'',desc:'Kopi premium hazelnut'},
    {id:'p3',name:'Butterscotch',price:12000,category:'premium',emoji:'💎',badge:'',desc:'Kopi premium butterscotch'},
    // Non-Coffee
    {id:'n1',name:'Matcha',price:10000,category:'noncoffee',emoji:'🧋',badge:'BEST SELLER',desc:'Minuman matcha'},
    {id:'n2',name:'Redvelvet',price:10000,category:'noncoffee',emoji:'🧋',badge:'',desc:'Red velvet creamy'},
    {id:'n3',name:'Taro',price:10000,category:'noncoffee',emoji:'🧋',badge:'',desc:'Minuman taro'},
    {id:'n4',name:'Choco',price:10000,category:'noncoffee',emoji:'🧋',badge:'BEST SELLER',desc:'Chocolate drink'},
];

const DEFAULT_USERS = {
    kasir1:{name:'Kasir 1',pin:'1234',role:'kasir'},
    kasir2:{name:'Kasir 2',pin:'2345',role:'kasir'},
    kasir3:{name:'Kasir 3',pin:'3456',role:'kasir'},
    admin:{name:'Admin',pin:'0000',role:'admin'}
};

// ==================== STATE ====================
let state = {
    currentUser: null,
    cart: [],
    transactions: [],
    menu: [],
    users: {},
    settings: {
        storeName:'Te.Co Pandawa',
        storeAddress:'Jl. Pandawa No. 123',
        storePhone:'0812-3456-7890',
        receiptFooter:'Terima kasih telah berkunjung!',
        taxRate: 10,
        serviceRate: 0,
        darkMode: false,
        sound: true,
        autoPrint: false,
        bluetoothPrinter: false
    },
    selectedProduct: null,
    selectedVariant: null,
    selectedPayment: 'cash',
    currentReceipt: null
};

// ==================== INIT ====================
function init() {
    loadData();
    if(!state.menu.length) state.menu = JSON.parse(JSON.stringify(DEFAULT_MENU));
    if(!Object.keys(state.users).length) state.users = JSON.parse(JSON.stringify(DEFAULT_USERS));
    if(!state.transactions.length) {
        // Generate sample transactions for demo
        generateSampleTransactions();
    }
    renderMenu('all');
    updateTime();
    setInterval(updateTime, 1000);
    setupCategoryTabs();
    document.getElementById('filterDate').value = new Date().toISOString().split('T')[0];

    // Setup login enter key
    document.getElementById('loginPass').addEventListener('keypress', function(e) {
        if(e.key === 'Enter') doLogin();
    });
}

function generateSampleTransactions() {
    const now = new Date();
    const items = DEFAULT_MENU;
    for(let i=0; i<15; i++) {
        const date = new Date(now);
        date.setDate(date.getDate() - Math.floor(Math.random() * 7));
        const item = items[Math.floor(Math.random() * items.length)];
        const qty = Math.floor(Math.random() * 3) + 1;
        const tx = {
            id: 'TX' + String(1000 + i).slice(1),
            date: date.toISOString(),
            items: [{...item, qty: qty}],
            subtotal: item.price * qty,
            tax: Math.round(item.price * qty * 0.1),
            total: Math.round(item.price * qty * 1.1),
            payment: ['cash','qris','transfer'][Math.floor(Math.random()*3)],
            cashier: ['kasir1','kasir2','kasir3'][Math.floor(Math.random()*3)],
            status: 'success'
        };
        state.transactions.push(tx);
    }
    saveData();
}

function loadData() {
    try {
        const saved = localStorage.getItem('teco_pos_data');
        if(saved) {
            const parsed = JSON.parse(saved);
            state.transactions = parsed.transactions || [];
            state.menu = parsed.menu || [];
            state.users = parsed.users || {};
            state.settings = {...state.settings, ...(parsed.settings || {})};
        }
    } catch(e) { console.error('Load error', e); }
}

function saveData() {
    try {
        localStorage.setItem('teco_pos_data', JSON.stringify({
            transactions: state.transactions,
            menu: state.menu,
            users: state.users,
            settings: state.settings
        }));
    } catch(e) { console.error('Save error', e); }
}

// ==================== LOGIN ====================
function doLogin() {
    const user = document.getElementById('loginUser').value;
    const pass = document.getElementById('loginPass').value;
    const error = document.getElementById('loginError');

    if(!user || !pass) {
        error.textContent = 'Pilih user dan masukkan PIN';
        error.style.display = 'block';
        return;
    }

    if(state.users[user] && state.users[user].pin === pass) {
        state.currentUser = {id: user, ...state.users[user]};
        document.getElementById('loginScreen').classList.add('hidden');
        document.getElementById('appContainer').classList.add('active');
        document.getElementById('headerUser').textContent = state.currentUser.name;
        document.getElementById('sideMenuUser').textContent = state.currentUser.name;

        if(state.currentUser.role === 'admin') {
            document.getElementById('navAdmin').style.display = 'flex';
            document.getElementById('sideMenuAdmin').style.display = 'flex';
        }

        playSound('login');
        showToast('Selamat datang, ' + state.currentUser.name + '!');

        setTimeout(() => {
            document.getElementById('loginScreen').style.display = 'none';
        }, 500);
    } else {
        error.textContent = 'PIN salah atau user tidak ditemukan';
        error.style.display = 'block';
        document.getElementById('loginPass').value = '';
        document.getElementById('loginPass').focus();
    }
}

function logout() {
    state.currentUser = null;
    document.getElementById('loginScreen').style.display = 'flex';
    document.getElementById('loginScreen').classList.remove('hidden');
    document.getElementById('appContainer').classList.remove('active');
    document.getElementById('loginUser').value = '';
    document.getElementById('loginPass').value = '';
    document.getElementById('loginError').style.display = 'none';
    document.getElementById('navAdmin').style.display = 'none';
    document.getElementById('sideMenuAdmin').style.display = 'none';
    clearCart();
    switchPage('pagePos');
}

// ==================== NAVIGATION ====================
function switchPage(pageId) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.getElementById(pageId).classList.add('active');
    document.querySelectorAll('.bottom-nav button').forEach(b => b.classList.remove('active'));

    const navMap = {'pagePos':0,'pageTrans':1,'pageReports':2,'pageAdmin':3,'pageSettings':4};
    const buttons = document.querySelectorAll('.bottom-nav button');
    const idx = navMap[pageId];
    if(idx !== undefined && buttons[idx]) buttons[idx].classList.add('active');

    if(pageId === 'pageTrans') { loadTransactions(); updateStats(); }
    if(pageId === 'pageReports') { loadReports(); }
    if(pageId === 'pageAdmin') { loadAdminData(); }
    if(pageId === 'pageSettings') { loadSettings(); }
}

function toggleSideMenu() {
    document.getElementById('sideMenu').classList.toggle('open');
    document.getElementById('sideMenuOverlay').classList.toggle('active');
}

// ==================== MENU ====================
function setupCategoryTabs() {
    document.querySelectorAll('.category-tab').forEach(tab => {
        tab.addEventListener('click', function() {
            document.querySelectorAll('.category-tab').forEach(t => t.classList.remove('active'));
            this.classList.add('active');
            renderMenu(this.dataset.cat);
        });
    });
}

function renderMenu(category) {
    const grid = document.getElementById('menuGrid');
    const items = category === 'all' ? state.menu : state.menu.filter(i => i.category === category);

    grid.innerHTML = items.map(item => `
        <div class="menu-item fade-in" onclick="openProductDetail('${item.id}')">
            <div class="menu-item-img">
                ${item.emoji}
                ${item.badge ? `<span class="menu-item-badge">${item.badge}</span>` : ''}
            </div>
            <div class="menu-item-info">
                <div class="menu-item-name">${item.name}</div>
                <div class="menu-item-price">Rp ${formatNumber(item.price)}</div>
                <div class="menu-item-desc">${item.desc}</div>
            </div>
        </div>
    `).join('');
}

function openProductDetail(itemId) {
    const item = state.menu.find(i => i.id === itemId);
    if(!item) return;
    state.selectedProduct = item;

    const variants = ['Dingin','Hangat'];
    document.getElementById('productDetail').innerHTML = `
        <div class="product-detail-img">${item.emoji}</div>
        <div class="product-detail-info">
            <h3>${item.name}</h3>
            <div class="detail-price">Rp ${formatNumber(item.price)}</div>
            <p>${item.desc}</p>
            <div class="variant-options">
                <label>Varian</label>
                <div class="variant-btns">
                    ${variants.map((v,i) => `<button class="variant-btn ${i===0?'active':''}" onclick="selectVariant(this,'${v}')">${v}</button>`).join('')}
                </div>
            </div>
        </div>
    `;
    state.selectedVariant = variants[0];
    openModal('productModal');
}

function selectVariant(btn, variant) {
    document.querySelectorAll('.variant-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    state.selectedVariant = variant;
}

function addToCartFromModal() {
    if(!state.selectedProduct) return;
    addToCart(state.selectedProduct, state.selectedVariant);
    closeModal('productModal');
}

// ==================== CART ====================
function addToCart(item, variant) {
    const existing = state.cart.find(c => c.id === item.id && c.variant === variant);
    if(existing) {
        existing.qty++;
    } else {
        state.cart.push({...item, qty: 1, variant: variant || 'Dingin'});
    }
    renderCart();
    playSound('add');
    showToast(item.name + ' ditambahkan!');
}

function renderCart() {
    const cartItems = document.getElementById('cartItems');
    const cartItemsMobile = document.getElementById('cartItemsMobile');
    const cartSummary = document.getElementById('cartSummary');
    const cartSummaryMobile = document.getElementById('cartSummaryMobile');
    const cartCount = document.getElementById('cartCount');
    const cartBadge = document.getElementById('cartBadge');

    const totalQty = state.cart.reduce((s,c) => s + c.qty, 0);
    cartCount.textContent = totalQty;
    cartBadge.textContent = totalQty;

    if(state.cart.length === 0) {
        cartItems.innerHTML = `
            <div class="empty-state">
                <div class="empty-icon">🛒</div>
                <p>Keranjang kosong</p>
            </div>`;
        cartSummary.style.display = 'none';
        if(cartItemsMobile) cartItemsMobile.innerHTML = cartItems.innerHTML;
        if(cartSummaryMobile) cartSummaryMobile.innerHTML = '';
        return;
    }

    const itemsHtml = state.cart.map((item, idx) => `
        <div class="cart-item">
            <div class="cart-item-img">${item.emoji}</div>
            <div class="cart-item-info">
                <div class="cart-item-name">${item.name} ${item.variant ? '('+item.variant+')' : ''}</div>
                <div class="cart-item-price">Rp ${formatNumber(item.price)}</div>
            </div>
            <div class="cart-item-qty">
                <button class="qty-btn" onclick="updateQty(${idx},-1)">−</button>
                <span class="qty-val">${item.qty}</span>
                <button class="qty-btn" onclick="updateQty(${idx},1)">+</button>
            </div>
            <div class="cart-item-total">Rp ${formatNumber(item.price * item.qty)}</div>
            <span class="remove-item" onclick="removeFromCart(${idx})">✕</span>
        </div>
    `).join('');

    cartItems.innerHTML = itemsHtml;
    if(cartItemsMobile) cartItemsMobile.innerHTML = itemsHtml;

    const subtotal = state.cart.reduce((s,c) => s + c.price * c.qty, 0);
    const tax = Math.round(subtotal * state.settings.taxRate / 100);
    const service = Math.round(subtotal * state.settings.serviceRate / 100);
    const total = subtotal + tax + service;

    const summaryHtml = `
        <div class="summary-row"><span>Subtotal</span><span>Rp ${formatNumber(subtotal)}</span></div>
        <div class="summary-row"><span>PPN (${state.settings.taxRate}%)</span><span>Rp ${formatNumber(tax)}</span></div>
        ${service ? `<div class="summary-row"><span>Service (${state.settings.serviceRate}%)</span><span>Rp ${formatNumber(service)}</span></div>` : ''}
        <div class="summary-row total"><span>TOTAL</span><span>Rp ${formatNumber(total)}</span></div>
        <button class="pay-btn" onclick="openPayment()">💳 Bayar Sekarang</button>
        <button class="clear-cart" onclick="clearCart()">🗑️ Kosongkan Keranjang</button>
    `;

    cartSummary.innerHTML = summaryHtml;
    cartSummary.style.display = 'block';
    if(cartSummaryMobile) cartSummaryMobile.innerHTML = summaryHtml;
}

function updateQty(idx, delta) {
    state.cart[idx].qty += delta;
    if(state.cart[idx].qty <= 0) state.cart.splice(idx, 1);
    renderCart();
}

function removeFromCart(idx) {
    state.cart.splice(idx, 1);
    renderCart();
}

function clearCart() {
    state.cart = [];
    renderCart();
    closeMobileCart();
}

function toggleMobileCart() {
    document.getElementById('cartPanelMobile').classList.toggle('active');
}

function closeMobileCart() {
    document.getElementById('cartPanelMobile').classList.remove('active');
}

// ==================== PAYMENT ====================
function openPayment() {
    if(state.cart.length === 0) { showToast('Keranjang masih kosong!'); return; }
    const subtotal = state.cart.reduce((s,c) => s + c.price * c.qty, 0);
    const tax = Math.round(subtotal * state.settings.taxRate / 100);
    const service = Math.round(subtotal * state.settings.serviceRate / 100);
    const total = subtotal + tax + service;
    document.getElementById('paymentTotal').textContent = 'Rp ' + formatNumber(total);
    document.getElementById('cashReceived').value = '';
    document.getElementById('changeDisplay').style.display = 'none';
    selectPayment('cash');
    openModal('paymentModal');
}

function selectPayment(method) {
    state.selectedPayment = method;
    document.querySelectorAll('.pay-method').forEach(m => m.classList.remove('active'));
    document.querySelector('[data-method="' + method + '"]').classList.add('active');
    document.getElementById('cashSection').style.display = method === 'cash' ? 'block' : 'none';
    document.getElementById('qrisSection').style.display = method === 'qris' ? 'block' : 'none';
    document.getElementById('transferSection').style.display = method === 'transfer' ? 'block' : 'none';
}

function setCash(amount) {
    document.getElementById('cashReceived').value = amount;
    calculateChange();
}

function setCashExact() {
    const subtotal = state.cart.reduce((s,c) => s + c.price * c.qty, 0);
    const tax = Math.round(subtotal * state.settings.taxRate / 100);
    const service = Math.round(subtotal * state.settings.serviceRate / 100);
    document.getElementById('cashReceived').value = subtotal + tax + service;
    calculateChange();
}

function calculateChange() {
    const received = parseInt(document.getElementById('cashReceived').value) || 0;
    const subtotal = state.cart.reduce((s,c) => s + c.price * c.qty, 0);
    const tax = Math.round(subtotal * state.settings.taxRate / 100);
    const service = Math.round(subtotal * state.settings.serviceRate / 100);
    const total = subtotal + tax + service;
    const change = received - total;

    if(received >= total) {
        document.getElementById('changeAmount').textContent = 'Rp ' + formatNumber(change);
        document.getElementById('changeDisplay').style.display = 'block';
    } else {
        document.getElementById('changeDisplay').style.display = 'none';
    }
}

function processPayment() {
    const subtotal = state.cart.reduce((s,c) => s + c.price * c.qty, 0);
    const tax = Math.round(subtotal * state.settings.taxRate / 100);
    const service = Math.round(subtotal * state.settings.serviceRate / 100);
    const total = subtotal + tax + service;

    if(state.selectedPayment === 'cash') {
        const received = parseInt(document.getElementById('cashReceived').value) || 0;
        if(received < total) { showToast('Uang tidak cukup!'); return; }
    }

    const tx = {
        id: 'TX' + Date.now().toString().slice(-6),
        date: new Date().toISOString(),
        items: JSON.parse(JSON.stringify(state.cart)),
        subtotal: subtotal,
        tax: tax,
        service: service,
        total: total,
        payment: state.selectedPayment,
        cashier: state.currentUser.id,
        cashierName: state.currentUser.name,
        status: 'success',
        received: state.selectedPayment === 'cash' ? (parseInt(document.getElementById('cashReceived').value) || total) : total,
        change: state.selectedPayment === 'cash' ? (parseInt(document.getElementById('cashReceived').value) || total) - total : 0
    };

    state.transactions.unshift(tx);
    saveData();

    state.currentReceipt = tx;
    renderReceipt(tx);
    closeModal('paymentModal');
    openModal('receiptModal');
    playSound('success');
    showToast('Transaksi berhasil! Rp ' + formatNumber(total));

    if(state.settings.autoPrint) {
        setTimeout(() => printReceipt(), 500);
    }
}

// ==================== RECEIPT ====================
function renderReceipt(tx) {
    const date = new Date(tx.date);
    const itemsHtml = tx.items.map(i => `
        <div class="receipt-item">
            <span>${i.qty}x ${i.name} ${i.variant ? '('+i.variant+')' : ''}</span>
            <span>Rp ${formatNumber(i.price * i.qty)}</span>
        </div>
    `).join('');

    document.getElementById('receiptContent').innerHTML = `
        <div class="receipt-header">
            <div class="receipt-logo">☕</div>
            <h3>${state.settings.storeName}</h3>
            <p>${state.settings.storeAddress}<br>Telp: ${state.settings.storePhone}</p>
        </div>
        <div class="receipt-divider"></div>
        <div class="receipt-item name"><span>No. Transaksi</span><span>${tx.id}</span></div>
        <div class="receipt-item"><span>Tanggal</span><span>${date.toLocaleString('id-ID')}</span></div>
        <div class="receipt-item"><span>Kasir</span><span>${tx.cashierName}</span></div>
        <div class="receipt-divider"></div>
        ${itemsHtml}
        <div class="receipt-divider"></div>
        <div class="receipt-item"><span>Subtotal</span><span>Rp ${formatNumber(tx.subtotal)}</span></div>
        <div class="receipt-item"><span>PPN (${state.settings.taxRate}%)</span><span>Rp ${formatNumber(tx.tax)}</span></div>
        ${tx.service ? `<div class="receipt-item"><span>Service</span><span>Rp ${formatNumber(tx.service)}</span></div>` : ''}
        <div class="receipt-item receipt-total"><span>TOTAL</span><span>Rp ${formatNumber(tx.total)}</span></div>
        ${tx.payment === 'cash' ? `
        <div class="receipt-item"><span>Tunai</span><span>Rp ${formatNumber(tx.received)}</span></div>
        <div class="receipt-item"><span>Kembalian</span><span>Rp ${formatNumber(tx.change)}</span></div>
        ` : `<div class="receipt-item"><span>Metode</span><span>${tx.payment.toUpperCase()}</span></div>`}
        <div class="receipt-divider"></div>
        <div class="receipt-footer">
            <div class="thanks">${state.settings.receiptFooter}</div>
            <p>-- Te.Co Pandawa POS --</p>
        </div>
    `;
}

function printReceipt() {
    window.print();
}

// ==================== TRANSACTIONS ====================
function loadTransactions() {
    const filterDate = document.getElementById('filterDate').value;
    const filterUser = document.getElementById('filterUser').value;

    let txs = state.transactions;
    if(filterDate) {
        txs = txs.filter(t => t.date.startsWith(filterDate));
    }
    if(filterUser) {
        txs = txs.filter(t => t.cashier === filterUser);
    }

    const list = document.getElementById('transactionList');
    if(txs.length === 0) {
        list.innerHTML = `
            <div class="empty-state">
                <div class="empty-icon">📋</div>
                <p>Tidak ada transaksi</p>
            </div>`;
        return;
    }

    list.innerHTML = txs.map(tx => {
        const date = new Date(tx.date);
        const payIcon = {cash:'💵',qris:'📱',transfer:'🏦'}[tx.payment] || '💳';
        return `
            <div class="transaction-item" onclick="viewReceipt('${tx.id}')">
                <div class="tx-icon">${payIcon}</div>
                <div class="tx-info">
                    <div class="tx-id">${tx.id}</div>
                    <div class="tx-meta">${date.toLocaleString('id-ID')} · ${tx.cashierName} · ${tx.items.length} item</div>
                </div>
                <div>
                    <div class="tx-amount">Rp ${formatNumber(tx.total)}</div>
                    <span class="tx-status ${tx.status}">${tx.status === 'success' ? '✓ Sukses' : '⏳ Pending'}</span>
                </div>
            </div>
        `;
