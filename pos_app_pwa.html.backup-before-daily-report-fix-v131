// ==================== UTILS ====================
function openModal(id) {
    document.getElementById(id).classList.add('active');
}

function closeModal(id) {
    document.getElementById(id).classList.remove('active');
}

function showToast(msg) {
    const toast = document.getElementById('toast');
    toast.textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2500);
}

function formatNumber(n) {
    return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.');
}

function updateTime() {
    const now = new Date();
    document.getElementById('headerTime').textContent = now.toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'});
}

function playSound(type) {
    if(!state.settings.sound) return;
    try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);

        if(type === 'add') {
            osc.frequency.value = 800;
            gain.gain.value = 0.1;
            osc.start(); osc.stop(ctx.currentTime + 0.1);
        } else if(type === 'success') {
            osc.frequency.value = 600;
            gain.gain.value = 0.15;
            osc.start();
            osc.frequency.setValueAtTime(800, ctx.currentTime + 0.1);
            osc.frequency.setValueAtTime(1000, ctx.currentTime + 0.2);
            osc.stop(ctx.currentTime + 0.3);
        } else if(type === 'login') {
            osc.frequency.value = 500;
            gain.gain.value = 0.1;
            osc.start();
            osc.frequency.setValueAtTime(700, ctx.currentTime + 0.15);
            osc.stop(ctx.currentTime + 0.3);
        }
    } catch(e) {}
}

