// ==================== REPORTS ====================
function switchReport(type) {
    document.querySelectorAll('.report-tab').forEach(t => t.classList.remove('active'));
    event.target.classList.add('active');
    loadReportData(type);
}

function loadReports() {
    loadReportData('daily');
}

function loadReportData(type) {
    const chart = document.getElementById('salesChart');
    const summary = document.getElementById('reportSummary');

    if(type === 'daily') {
        const days = {};
        for(let i=6; i>=0; i--) {
            const d = new Date();
            d.setDate(d.getDate() - i);
            const key = d.toISOString().split('T')[0];
            days[key] = {label: d.toLocaleDateString('id-ID',{weekday:'short'}), total:0, count:0};
        }
        state.transactions.forEach(t => {
            const d = t.date.split('T')[0];
            if(days[d]) { days[d].total += t.total; days[d].count++; }
        });

        const values = Object.values(days);
        const maxVal = Math.max(...values.map(v => v.total), 1);

        chart.innerHTML = values.map(v => `
            <div class="chart-bar-item" style="height:${(v.total/maxVal*100)}%">
                <span class="bar-value">${v.count}</span>
                <span class="bar-label">${v.label}</span>
            </div>
        `).join('');

        const totalWeek = values.reduce((s,v) => s + v.total, 0);
        summary.innerHTML = `
            <div class="setting-item">
                <div class="setting-info"><div class="setting-name">Total Minggu Ini</div></div>
                <div class="setting-action">Rp ${formatNumber(totalWeek)}</div>
            </div>
            <div class="setting-item">
                <div class="setting-info"><div class="setting-name">Rata-rata Harian</div></div>
                <div class="setting-action">Rp ${formatNumber(Math.round(totalWeek/7))}</div>
            </div>
        `;
    } else if(type === 'monthly') {
        const months = {};
        state.transactions.forEach(t => {
            const m = t.date.slice(0, 7);
            if(!months[m]) months[m] = {label: m, total:0, count:0};
            months[m].total += t.total;
            months[m].count++;
        });

        const values = Object.values(months).slice(-6);
        const maxVal = Math.max(...values.map(v => v.total), 1);

        chart.innerHTML = values.map(v => `
            <div class="chart-bar-item" style="height:${(v.total/maxVal*100)}%">
                <span class="bar-value">${v.count}</span>
                <span class="bar-label">${v.label}</span>
            </div>
        `).join('');

        const total = values.reduce((s,v) => s + v.total, 0);
        summary.innerHTML = `
            <div class="setting-item">
                <div class="setting-info"><div class="setting-name">Total 6 Bulan Terakhir</div></div>
                <div class="setting-action">Rp ${formatNumber(total)}</div>
            </div>
        `;
    } else {
        const products = {};
        state.transactions.forEach(t => {
            t.items.forEach(i => {
                if(!products[i.name]) products[i.name] = {count:0, revenue:0};
                products[i.name].count += i.qty;
                products[i.name].revenue += i.price * i.qty;
            });
        });

        const sorted = Object.entries(products).sort((a,b) => b[1].count - a[1].count).slice(0, 7);
        const maxVal = Math.max(...sorted.map(v => v[1].count), 1);

        chart.innerHTML = sorted.map(v => `
            <div class="chart-bar-item" style="height:${(v[1].count/maxVal*100)}%">
                <span class="bar-value">${v[1].count}</span>
                <span class="bar-label">${v[0].substring(0,8)}</span>
            </div>
        `).join('');

        summary.innerHTML = sorted.map(v => `
            <div class="setting-item">
                <div class="setting-info">
                    <div class="setting-name">${v[0]}</div>
                    <div class="setting-desc">${v[1].count} terjual</div>
                </div>
                <div class="setting-action">Rp ${formatNumber(v[1].revenue)}</div>
            </div>
        `).join('');
    }
}

